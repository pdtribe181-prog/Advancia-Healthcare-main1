# Frontend Environment Configuration
# Copy this file to .env and fill in actual values.
# Provide these values to the frontend host (Cloudflare/Render/VPS) and to GitHub Actions if CI builds the frontend.

# API Base URL (backend server). For production (Cloudflare Pages) set to:
# VITE_API_URL=https://api.advanciapayledger.com/api/v1
VITE_API_URL=http://127.0.0.1:3000/api/v1

# Stripe Publishable Key (use test key for development)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Supabase Configuration (optional - for direct DB access)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Error Tracking (Sentry)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Feature Flags
VITE_ENABLE_ANALYTICS=false
