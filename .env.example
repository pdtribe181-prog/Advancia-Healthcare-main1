# Backend Environment Configuration
# Copy this file to .env and fill in actual values
# Mirror the same keys into GitHub Actions repository secrets for CI/E2E.

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-for-db-triggers

# Direct Database Connection (for migrations)
# Find in: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Supabase Management API (for running migrations via REST)
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Advancia PayLedger <noreply@advanciapayledger.com>

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Redis / Upstash (optional â€“ falls back to in-memory if not set)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# Standard Redis fallback (only used if Upstash vars are not set)
# REDIS_URL=redis://localhost:6379

# Blockchain / Alchemy (optional â€“ for custom RPC or future wallet features)
# ALCHEMY_API_KEY=your-alchemy-api-key

# Error Tracking & Monitoring (Sentry)
# Get from: https://sentry.io
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=development

# Frontend URL (Stripe redirects, password reset, identity link callback).
# Production: https://advanciapayledger.com
FRONTEND_URL=http://localhost:5173

# Optional: extra allowed CORS origins (comma-separated). Production code also allows
# advanciapayledger.com, www, app, advancia-healthcare.com, www by default.
# CORS_ORIGINS=https://advanciapayledger.com,https://www.advanciapayledger.com,https://advancia-healthcare.com,https://www.advancia-healthcare.com

# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting Configuration (optional - defaults shown)
# API rate limit (general endpoints)
# RATE_LIMIT_API_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=100

# Auth rate limit (login, register)
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=10

# Payment rate limit
# RATE_LIMIT_PAYMENT_WINDOW_MS=60000
# RATE_LIMIT_PAYMENT_MAX=10

# Sensitive operations rate limit (refunds, transfers)
# RATE_LIMIT_SENSITIVE_WINDOW_MS=3600000
# RATE_LIMIT_SENSITIVE_MAX=20

# Webhook rate limit
# RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
# RATE_LIMIT_WEBHOOK_MAX=100

# Provider onboarding rate limit
# RATE_LIMIT_ONBOARDING_WINDOW_MS=3600000
# RATE_LIMIT_ONBOARDING_MAX=5

# Advancia-Healthcare-main1 local: use 3001 to avoid conflict with modullar-advancia
PORT=3001

