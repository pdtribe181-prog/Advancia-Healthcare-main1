# Production Environment Configuration
# Copy to .env for production deployment

# Node Environment
NODE_ENV=production
PORT=3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration (Use LIVE keys for production)
STRIPE_SECRET_KEY=sk_live_your-live-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-production-webhook-secret

# Frontend URL (password reset, identity link callback). Primary app domain.
FRONTEND_URL=https://advanciapayledger.com

# Optional: extra CORS origins (comma-separated). These are already allowed by default:
# advanciapayledger.com, www, app, advancia-healthcare.com, www
# CORS_ORIGINS=

# Rate Limiting (can be adjusted per environment)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Security
TRUST_PROXY=true
HELMET_ENABLED=true
