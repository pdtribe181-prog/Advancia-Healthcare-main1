# E2E/Test Environment Configuration
# Copy this file to .env (or .env.e2e if you prefer) and fill with
# TEST-ONLY values (never production secrets). Used for local E2E.

# Base URLs
API_BASE_URL=http://127.0.0.1:3000
FRONTEND_URL=http://127.0.0.1:5173

# Supabase (use a dedicated TEST project, not prod/staging)
SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_ANON_KEY=your-test-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
SUPABASE_WEBHOOK_SECRET=your-test-webhook-secret
DATABASE_URL=postgresql://postgres:[TEST-PASSWORD]@db.[YOUR-TEST-PROJECT].supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=sbp_your_test_personal_access_token

# Stripe (test keys only)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret_here

# Email (Resend test key)
RESEND_API_KEY=re_your_test_api_key_here
EMAIL_FROM=Advancia PayLedger Test <noreply@test.advanciapayledger.com>

# SMS (Twilio test credentials)
TWILIO_ACCOUNT_SID=AC_your_test_account_sid_here
TWILIO_AUTH_TOKEN=your_test_auth_token_here
TWILIO_PHONE_NUMBER=+10000000000

# Redis / Upstash (optional for rate limiting in tests)
UPSTASH_REDIS_REST_URL=https://your-test-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-test-upstash-rest-token

# Sentry (optional for tests)
SENTRY_DSN=
SENTRY_ENVIRONMENT=e2e

# Server configuration
PORT=3000
NODE_ENV=test

# Optional CORS origins for E2E
# CORS_ORIGINS=http://127.0.0.1:5173

# Optional rate limit overrides for faster E2E
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_API_MAX=1000
