upstream advancia_backend {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 443 ssl;
    server_name api.advanciapayledger.com;

    ssl_certificate /etc/letsencrypt/live/api.advanciapayledger.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.advanciapayledger.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    access_log /var/log/nginx/api-advancia.access.log;
    error_log /var/log/nginx/api-advancia.error.log;

    # Security headers handled by Express/Helmet — only add HSTS here (not duplicated by Helmet)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Proxy everything to Express
    location / {
        proxy_pass http://advancia_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Stripe webhooks can be large
        client_max_body_size 10M;
    }
}

server {
    listen 80;
    server_name api.advanciapayledger.com;
    return 301 https://$host$request_uri;
}
