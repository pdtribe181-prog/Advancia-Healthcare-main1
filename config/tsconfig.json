{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../dist",
    "rootDir": "../src",
    "types": ["node", "jest"],
    "noUnusedLocals": false
  },
  "include": ["../src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "migrations",
    "../src/**/*.test.ts",
    "../src/**/__tests__/**/*",
    "**/*.spec.ts"
  ]
}
