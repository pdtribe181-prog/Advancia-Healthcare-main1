# Staging Environment Configuration (Render + Supabase)
# Copy values into Render service env vars (or local .env for staging tests)

NODE_ENV=staging
PORT=3000

# Supabase (STAGING project only)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
SUPABASE_WEBHOOK_SECRET=your-staging-webhook-secret

# Stripe (test keys for staging)
STRIPE_SECRET_KEY=sk_test_your_staging_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_staging_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_staging_webhook_secret

# Frontend / CORS (staging hostnames)
FRONTEND_URL=https://staging.advanciapayledger.com
CORS_ORIGINS=https://staging.advanciapayledger.com

# Email / SMS (optional in staging)
RESEND_API_KEY=re_your_staging_api_key
EMAIL_FROM=Advancia PayLedger Staging <noreply@advanciapayledger.com>
TWILIO_ACCOUNT_SID=AC_your_staging_account_sid
TWILIO_AUTH_TOKEN=your_staging_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Monitoring
SENTRY_DSN=https://your-staging-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=staging

# Redis / Upstash (recommended)
UPSTASH_REDIS_REST_URL=https://your-staging-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-staging-upstash-token
