# Normalize line endings across the repo.
# This helps avoid CRLF/LF churn and spurious dirty working trees on Windows.

* text=auto

# Source
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf

# Config / docs
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.sh text eol=lf
*.sql text eol=lf

# PowerShell (keep CRLF for best Windows compatibility)
*.ps1 text eol=crlf
