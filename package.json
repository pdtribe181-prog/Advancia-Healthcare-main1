{
  "name": "modullar-advancia",
  "version": "1.0.0",
  "description": "Healthcare payment and compliance management platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "node config/esbuild.config.js",
    "postbuild": "node -e \"require('fs').copyFileSync('openapi.yaml', 'dist/openapi.yaml')\" && echo Build completed successfully",
    "start": "node dist/server.js",
    "dev": "tsx --watch src/server.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:api": "npx playwright test --config config/playwright.api.config.ts",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:connection": "tsx test-connection.ts",
    "playwright:install": "npx playwright install --with-deps",
    "typecheck": "tsc --noEmit -p config/tsconfig.json",
    "typecheck:build": "tsc --noEmit -p config/tsconfig.build.json",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix",
    "format": "npx prettier --write \"src/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "clean": "rimraf dist",
    "build:prod": "npm run clean && npm run build",
    "docker:build": "docker build -f config/Dockerfile -t healthcare-payment-api .",
    "docker:run": "docker run -p 3000:3000 --env-file .env healthcare-payment-api",
    "preflight": "tsx scripts/preflight-check.ts",
    "test:email": "tsx scripts/test-email-templates.ts",
    "test:sms": "tsx scripts/test-sms-templates.ts",
    "load-test": "tsx scripts/load-test.ts",
    "uptime": "tsx scripts/uptime-monitor.ts",
    "stripe:go-live": "tsx scripts/stripe-go-live.ts",
    "stripe:webhooks": "tsx scripts/test-stripe-webhooks.ts",
    "secrets:setup": "tsx scripts/setup-gh-secrets.ts",
    "secrets:rotate": "tsx scripts/rotate-secrets.ts",
    "deploy:vps": "tsx scripts/vps-deploy.ts",
    "verify:dns": "tsx scripts/verify-dns.ts",
    "verify:domains": "tsx scripts/verify-all-domains.ts",
    "cloudflare:check": "tsx scripts/cloudflare-setup.ts",
    "staging:setup": "tsx scripts/staging-setup.ts",
    "lighthouse": "tsx scripts/lighthouse-audit.ts",
    "logs:setup": "tsx scripts/log-aggregation.ts",
    "health:check": "tsx scripts/server-health-monitor.ts",
    "health:json": "tsx scripts/server-health-monitor.ts --json",
    "memory:test": "tsx scripts/memory-leak-test.ts",
    "push:mirror": "git push origin main && git push together main"
  },
  "keywords": [
    "healthcare",
    "payments",
    "supabase",
    "compliance"
  ],
  "engines": {
    "node": "20.x"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.41.0",
    "@sentry/types": "^10.41.0",
    "@supabase/supabase-js": "^2.95.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "lru-cache": "^11.2.6",
    "multer": "^2.0.2",
    "postgres": "^3.4.8",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.9.2",
    "stripe": "^20.3.1",
    "swagger-ui-express": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "twilio": "^5.12.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sentry/esbuild-plugin": "^5.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.27.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.1",
    "openapi-types": "^12.1.3",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "tar": ">=6.2.1",
    "form-data": ">=4.0.2",
    "qs": ">=6.14.1",
    "tough-cookie": ">=4.1.4",
    "minimatch": "^7.4.6"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
